{
  "name": "@grain/binaryen.ml",
  "version": "0.26.0",
  "description": "OCaml bindings for Binaryen.",
  "author": "Oscar Spencer <oscar@grain-lang.org>",
  "license": "Apache-2.0",
  "esy": {
    "build": "dune build -p binaryen"
  },
  "dependencies": {
    "ocaml": ">= 4.13.0 < 5.0.0",
    "@grain/libbinaryen": ">= 117.0.0 < 118.0.0",
    "@opam/dune": ">= 3.0.0",
    "@opam/dune-configurator": ">= 3.0.0"
  },
  "devDependencies": {
    "@opam/js_of_ocaml-compiler": ">= 6.0.0 < 7.0.0",
    "@opam/ocamlformat": "0.24.1",
    "@opam/ocaml-lsp-server": ">= 1.9.1 < 1.18.0"
  },
  "resolutions": {
    "@opam/ocp-indent": "1.7.0",
    "@grain/libbinaryen": {
      "source": "archive:https://registry.npmjs.org/@grain/libbinaryen/-/libbinaryen-117.0.0.tgz#sha1:0bb32f24a9016486b98e93f464017a357f5d86e7",
      "override": {
        "esy": {
          "build": [
            "bash -c #{os == 'windows' ? 'curl -s https://raw.githubusercontent.com/spotandjake/binaryen.ml/refs/heads/spotandjake-117/winpatch.patch | patch -p1' : 'true'}",
            "dune build -p libbinaryen -j 4"
          ]
        }
      }
    }
  },
  "scripts": {
    "test": "esy b dune runtest --display=short",
    "format": "dune build @fmt --auto-promote"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "binaryen",
    "ocaml"
  ]
}